# Copy to .env and fill in real values. NEVER commit the real .env.
# For `docker compose up`, every value below already has a safe DEV default in
# docker-compose.yml — so the stack runs out of the box. Override here for real use.

# --- PostgreSQL (docker-compose) ---
POSTGRES_DB=minishop
POSTGRES_USER=minishop
POSTGRES_PASSWORD=minishop
POSTGRES_PORT=5432

# --- Backend datasource ---
# Inside docker-compose the host is the `postgres` service, not localhost:
#   DB_URL=jdbc:postgresql://postgres:5432/minishop
# For running the backend on the host (outside compose) use localhost:
DB_URL=jdbc:postgresql://localhost:5432/minishop
DB_USER=minishop
DB_PASSWORD=minishop

# --- Security ---
# Base64-encoded secret for signing JWT (min 256 bits).
# docker-compose ships a DEV-ONLY default; ⚠ ALWAYS set your own value in production.
JWT_SECRET=
# Access token time-to-live, ISO-8601 duration (e.g. PT1H)
JWT_TTL=PT1H

# --- Spring profile ---
# `prod` (compose default) = stricter logging; `dev` = verbose + SQL tracing.
SPRING_PROFILES_ACTIVE=prod

# --- CORS ---
# Comma-separated list of allowed frontend origins. With the nginx same-origin proxy
# this is not exercised by the browser, but keep it aligned with the frontend URL.
CORS_ALLOWED_ORIGINS=http://localhost:8081

# --- Frontend (docker-compose) ---
# Host port the frontend (nginx) is published on; open http://localhost:<port>.
FRONTEND_PORT=8081

# --- Admin seed (dev only) ---
# Matches the BCrypt hash seeded by V3__seed_admin.sql.
# email: admin@shop.local  password: Admin123!
# In production, generate a new BCrypt hash and update the migration before first run.
