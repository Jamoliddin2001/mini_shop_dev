# Backend environment template. Copy to .env and fill in real values.
# .env is git-ignored — NEVER commit real secrets.

# --- Datasource (read by Spring via application.yml) ---
DB_URL=jdbc:postgresql://localhost:5432/minishop
DB_USER=minishop
DB_PASSWORD=

# --- Active Spring profile ---
SPRING_PROFILES_ACTIVE=dev

# --- Security (used from the security/auth phase) ---
# Base64-encoded signing key, at least 256 bits. Generate your own; do not reuse.
JWT_SECRET=
# Access token TTL as ISO-8601 duration, e.g. PT1H
JWT_TTL=PT1H

# --- CORS ---
# Comma-separated allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173
