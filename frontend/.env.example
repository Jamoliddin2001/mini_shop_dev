# Copy to .env.local for local development. Vite exposes only VITE_*-prefixed vars to the client.
# No secrets here — the JWT is obtained at runtime via /api/auth/login, never baked into the bundle.

# Base URL of the backend API (Spring Boot, default port 8080). Includes the /api prefix.
VITE_API_BASE_URL=http://localhost:8080/api
